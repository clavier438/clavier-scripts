<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.clavier.watcherGitSync</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/doppler</string>
        <string>run</string>
        <string>--project</string>
        <string>clavier</string>
        <string>--config</string>
        <string>prd</string>
        <string>--silent</string>
        <string>--</string>
        <string>/bin/bash</string>
        <string>/Users/clavier/Library/Mobile Documents/com~apple~CloudDocs/0/scripts/daemons/gitSync.sh</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>/Users/clavier/Library/Mobile Documents/com~apple~CloudDocs/0/scripts</string>
    </array>
    <key>StartInterval</key><integer>300</integer>
    <key>ThrottleInterval</key><integer>60</integer>
    <key>RunAtLoad</key><false/>
    <key>StandardOutPath</key><string>/Users/clavier/Library/Logs/gitSync.log</string>
    <key>StandardErrorPath</key><string>/Users/clavier/Library/Logs/gitSync_error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key><string>/Users/clavier</string>
    </dict>
</dict>
</plist>
