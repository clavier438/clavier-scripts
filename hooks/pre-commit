#!/usr/bin/env bash
# pre-commit — SSOT 강제 장치 네 개.
#
# (1) main 직접 커밋 차단.
#     SSOT = origin/main. main 은 PR 로만 바뀐다. 로컬 main 에 커밋이 쌓이면
#     branch protection 때문에 push 도 못 하고, drift 의 시작점이 된다.
#     작업은 항상 브랜치에서 → PR 로 보이고, 숨은 브랜치가 생기지 않는다.
#
# (2) freshness import 강제.
#     모든 tools/*.{mjs,sh,py} 와 daemons/*.{sh,py} 는 첫 50 줄 안에
#     tools/lib/freshness.{mjs,sh,py} 참조가 있어야 한다. 없으면 commit 차단.
#     → "freshness 체크 없는 tool" 이 repo 에 존재할 수 없음 →
#       모든 invocation 은 origin/main 동기화 후에만 실행됨.
#
# (3) capability docs 자동 generate.
#     도구 코드 안의 CAPABILITY_DOC const → capabilities/<name>.md 로 자동 sync.
#     도구 = 진실 소스. capability doc = derived. drift 자체가 불가능.
#
# (4) Doppler --config 리터럴 차단 (P7, Ray Dalio 2026-05-25).
#     `--config prd` (또는 stg/dev) 리터럴 = multi-worker drift 위험. 정답 = `--config "${DOPPLER_CONFIG:-prd}"`.
#     diff 의 *신규 추가 라인* 만 검사 — 기존 코드는 점진 마이그레이션. `${DOPPLER_CONFIG` 사용 패턴은 escape hatch.
#
# (5) front door 통합 환기 (그루핑 원칙, CLAUDE.md "단일 front door + verb").
#     새 실행 스크립트가 front door verb 로 안 묶이고 ~/bin 독립 떠돌이가 되는 것을
#     방지 — image-*/photo-* 가 그룹 없이 우수수 떠돌던 패턴의 재발 차단.
#     front door(verb 라우터)·내부 모듈·라이브러리는 제외. 판정 휴리스틱이라 *경고만*.
#
# (제거됨 2026-06-09, hook GC) "Mac 호스트별 단일 클론 강제" 검사.
#     ~/bin alias 가 가리키는 클론만 canonical 로 지정하고 그 외(특히 git worktree)의
#     commit 을 차단했음. 그러나 (a) environment-peer ADR(2026-05-03)이 "특정 경로를
#     canonical 로 지정하지 않음 — 어느 환경이든 동등 peer" 로 폐기한 규칙이고,
#     (b) git worktree 격리를 commit 불가로 만들어 단일 작업트리 공유 → 멀티세션
#     브랜치 충돌을 조장했다. 옛 stale-clone 방어는 environment-peer 의 "세션 시작
#     fetch+status / 종료 commit+push" 위생으로 대체. (막은 실수 0 / 유발 마찰 다수)

# ── (1) main 직접 커밋 차단 ──────────────────────────────────────────────
branch="$(git symbolic-ref --short HEAD 2>/dev/null)"
if [ "$branch" = "main" ]; then
    echo "" >&2
    echo "‼️  main 에 직접 커밋할 수 없습니다." >&2
    echo "    작업 브랜치를 만드세요:  git switch -c <작업이름>" >&2
    echo "" >&2
    exit 1
fi

# ── (2) freshness import 강제 ────────────────────────────────────────────
violations=()
while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ ! -f "$f" ] && continue  # 삭제된 파일 skip

    # 라이브러리/hook 자체는 제외 (검사 대상이 아니라 검사를 *하는* 쪽)
    case "$f" in
        tools/lib/*) continue ;;
        hooks/*) continue ;;
    esac

    # 확장자별로 freshness 참조 키워드 확인
    case "$f" in
        tools/*.mjs|tools/*.js)
            head -50 "$f" | grep -qE 'lib/freshness\.mjs' \
                || violations+=("$f  →  import \"./lib/freshness.mjs\"")
            ;;
        tools/*.sh|daemons/*.sh)
            head -50 "$f" | grep -qE 'lib/freshness\.sh' \
                || violations+=("$f  →  . \"\$(dirname …)/lib/freshness.sh\" 형식")
            ;;
        tools/*.py|daemons/*.py)
            head -50 "$f" | grep -qE 'lib/freshness|import freshness' \
                || violations+=("$f  →  sys.path.insert + import freshness")
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=AM)

if [ ${#violations[@]} -gt 0 ]; then
    echo "" >&2
    echo "‼️  freshness 체크 누락 — 아래 파일은 첫 50 줄 안에 freshness import 가 있어야 합니다:" >&2
    echo "" >&2
    for v in "${violations[@]}"; do
        echo "    $v" >&2
    done
    echo "" >&2
    echo "  → 자세한 형식: tools/lib/freshness.{mjs,sh,py} 헤더 참조" >&2
    echo "" >&2
    exit 1
fi

# ── (3) capability docs 자동 generate ────────────────────────────────────
#       도구 코드 안의 CAPABILITY_DOC const → capabilities/<name>.md 로 자동 sync.
#       도구 = 진실 소스. capability doc = derived. drift 자체가 불가능하게.
#
#       generator 룰: tools/<name>.mjs 변경 시 → node tools/<name> --print-capability
#                     → tools/capabilities/<doc-name>.md 로 write + git add.
#       (macOS bash 3.2 호환 위해 case statement 사용; associative array X)
while IFS= read -r src; do
    case "$src" in
        tools/airtableUpsertV6.mjs)
            dst="tools/capabilities/airtable-v6.md"
            ;;
        # 추가 도구 →
        # tools/yourTool.mjs)
        #     dst="tools/capabilities/your-doc.md"
        #     ;;
        *)
            continue ;;
    esac
    [ -f "$src" ] || continue
    CLAVIER_LOCAL_DEV=1 node "$src" --print-capability > "$dst" 2>/dev/null
    git add "$dst"
    echo "  ⚙  $dst regenerated from $src" >&2
done < <(git diff --cached --name-only --diff-filter=AM)

# ── (4) Doppler --config 리터럴 차단 (P7) ───────────────────────────────
#       정답 = `--config "${DOPPLER_CONFIG:-prd}"`. 리터럴 prd/stg/dev 는 multi-worker drift.
#       *신규 추가 라인* (`^+` in unified diff, `^+++` 헤더 제외) 만 검사.
#       `${DOPPLER_CONFIG` 사용 라인은 통과 (escape hatch).
doppler_violations=()
while IFS= read -r line; do
    [ -z "$line" ] && continue
    case "$line" in
        +++*) continue ;;
        +*)
            content="${line#+}"
            case "$content" in
                *'${DOPPLER_CONFIG'*) continue ;;
            esac
            # 주석/도움말 텍스트는 실행 코드가 아니다 — Sentinel markNonCodeLines 과 동일 원칙.
            # 한 줄 detector 가 console.log/주석 안 `--config prd` 를 코드 drift 로 오탐하던 blind spot.
            trimmed="${content#"${content%%[![:space:]]*}"}"
            case "$trimmed" in
                '//'*|'#'*|'*'*|'/*'*) continue ;;
            esac
            if echo "$content" | grep -qE -- '--config[= ]+(prd|stg|dev)([^a-zA-Z_]|$)'; then
                doppler_violations+=("$content")
            fi
            ;;
    esac
done < <(git diff --cached --no-color -U0 -- 'tools/*' 'daemons/*' 2>/dev/null)

if [ ${#doppler_violations[@]} -gt 0 ]; then
    echo "" >&2
    echo "‼️  Doppler --config 리터럴 추가 차단 (P7, PRINCIPLES.md) — multi-worker drift 위험:" >&2
    echo "" >&2
    for v in "${doppler_violations[@]}"; do
        echo "    + $v" >&2
    done
    echo "" >&2
    echo "  → 정답: --config \"\${DOPPLER_CONFIG:-prd}\"" >&2
    echo "  → 예외 escape: \${DOPPLER_CONFIG 사용 시 통과" >&2
    echo "" >&2
    exit 1
fi

# ── (5) front door 통합 환기 (그루핑 원칙, CLAUDE.md "단일 front door + verb") ──
#       새로 추가된 실행 스크립트가 어떤 front door verb 로도 안 묶이고 ~/bin 에
#       독립 떠돌이로 노출되는 것을 방지 — image-*/photo-* 가 그룹 없이 우수수
#       떠돌던 패턴의 재발 차단. 단, "front door 인가 / 내부 모듈인가" 판정은
#       휴리스틱이라 false positive 가 가능 → *경고만* (차단 아님).
#
#       제외 = 라이브러리(lib/) · front door 자체(verb 라우터) · 내부 모듈
#              (다른 tools 가 파일명으로 호출 = 위임받는 쪽).
#       남는 것 = 아무도 안 부르고 verb 라우터도 아닌 실행 스크립트 = 떠돌이 후보.
frontdoor_orphans=()
while IFS= read -r f; do
    [ -f "$f" ] || continue
    case "$f" in
        tools/lib/*) continue ;;
        tools/*.py|tools/*.mjs|tools/*.sh) ;;
        *) continue ;;
    esac
    # 실행 진입점이 있는 스크립트만 (순수 라이브러리/모듈은 대상 아님)
    grep -qE '__main__|^main\b|function main\b|def main\b' "$f" || continue
    # front door 인가? (verb 라우터 = table/choices/add_parser/verb/case 패턴) → 정당
    grep -qE 'table[[:space:]]*=[[:space:]]*\{|choices=|add_parser|verb|case .* in' "$f" && continue
    # 다른 tools 파일이 이 파일명을 호출(위임)하는가? → 내부 모듈, 정당
    base="$(basename "$f")"
    others=$(grep -rlF "$base" tools/ --include='*.py' --include='*.mjs' --include='*.sh' 2>/dev/null | grep -vxF "$f")
    [ -n "$others" ] && continue
    frontdoor_orphans+=("$f")
done < <(git diff --cached --name-only --diff-filter=A)

if [ ${#frontdoor_orphans[@]} -gt 0 ]; then
    echo "" >&2
    echo "⚠️  front door 미통합 스크립트 — 그루핑 원칙 (CLAUDE.md \"단일 front door + verb\"):" >&2
    echo "" >&2
    for o in "${frontdoor_orphans[@]}"; do
        echo "    $o" >&2
    done
    echo "" >&2
    echo "  → 기존 front door(img / brandRe / workerCtl / framer / copy) 의 verb 로 넣거나," >&2
    echo "     새 front door 를 만들어 그 verb 로만 노출하세요. ~/bin 독립 떠돌이 금지." >&2
    echo "  (정말 독립 진입점이어야 하면 무시 — 경고일 뿐 차단 아님)" >&2
    echo "" >&2
fi
