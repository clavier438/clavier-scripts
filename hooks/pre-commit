#!/usr/bin/env bash
# pre-commit — SSOT 강제 장치 네 개.
#
# (1) main 직접 커밋 차단.
#     SSOT = origin/main. main 은 PR 로만 바뀐다. 로컬 main 에 커밋이 쌓이면
#     branch protection 때문에 push 도 못 하고, drift 의 시작점이 된다.
#     작업은 항상 브랜치에서 → PR 로 보이고, 숨은 브랜치가 생기지 않는다.
#
# (2) freshness import 강제.
#     모든 tools/*.{mjs,sh,py} 와 daemons/*.{sh,py} 는 첫 50 줄 안에
#     tools/lib/freshness.{mjs,sh,py} 참조가 있어야 한다. 없으면 commit 차단.
#     → "freshness 체크 없는 tool" 이 repo 에 존재할 수 없음 →
#       모든 invocation 은 origin/main 동기화 후에만 실행됨.
#
# (3) capability docs 자동 generate.
#     도구 코드 안의 CAPABILITY_DOC const → capabilities/<name>.md 로 자동 sync.
#     도구 = 진실 소스. capability doc = derived. drift 자체가 불가능.
#
# (4) Mac 호스트별 단일 클론 강제.
#     ~/bin/* alias 들이 가리키는 dir = 이 호스트의 *실제 사용* canonical.
#     같은 Mac 안 두 번째 클론에서 commit 시도하면 차단 + canonical 위치 안내.
#     → "사용자가 모르는 stale 클론에서 작업한 결과가 push 됨" 시나리오 닫힘.
#     ~/bin 없는 환경 (OCI/web) → skip (environment-peer 모델 호환).

# ── (1) main 직접 커밋 차단 ──────────────────────────────────────────────
branch="$(git symbolic-ref --short HEAD 2>/dev/null)"
if [ "$branch" = "main" ]; then
    echo "" >&2
    echo "‼️  main 에 직접 커밋할 수 없습니다." >&2
    echo "    작업 브랜치를 만드세요:  git switch -c <작업이름>" >&2
    echo "" >&2
    exit 1
fi

# ── (2) freshness import 강제 ────────────────────────────────────────────
violations=()
while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ ! -f "$f" ] && continue  # 삭제된 파일 skip

    # 라이브러리/hook 자체는 제외 (검사 대상이 아니라 검사를 *하는* 쪽)
    case "$f" in
        tools/lib/*) continue ;;
        hooks/*) continue ;;
    esac

    # 확장자별로 freshness 참조 키워드 확인
    case "$f" in
        tools/*.mjs|tools/*.js)
            head -50 "$f" | grep -qE 'lib/freshness\.mjs' \
                || violations+=("$f  →  import \"./lib/freshness.mjs\"")
            ;;
        tools/*.sh|daemons/*.sh)
            head -50 "$f" | grep -qE 'lib/freshness\.sh' \
                || violations+=("$f  →  . \"\$(dirname …)/lib/freshness.sh\" 형식")
            ;;
        tools/*.py|daemons/*.py)
            head -50 "$f" | grep -qE 'lib/freshness|import freshness' \
                || violations+=("$f  →  sys.path.insert + import freshness")
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=AM)

if [ ${#violations[@]} -gt 0 ]; then
    echo "" >&2
    echo "‼️  freshness 체크 누락 — 아래 파일은 첫 50 줄 안에 freshness import 가 있어야 합니다:" >&2
    echo "" >&2
    for v in "${violations[@]}"; do
        echo "    $v" >&2
    done
    echo "" >&2
    echo "  → 자세한 형식: tools/lib/freshness.{mjs,sh,py} 헤더 참조" >&2
    echo "" >&2
    exit 1
fi

# ── (3) capability docs 자동 generate ────────────────────────────────────
#       도구 코드 안의 CAPABILITY_DOC const → capabilities/<name>.md 로 자동 sync.
#       도구 = 진실 소스. capability doc = derived. drift 자체가 불가능하게.
#
#       generator 룰: tools/<name>.mjs 변경 시 → node tools/<name> --print-capability
#                     → tools/capabilities/<doc-name>.md 로 write + git add.
#       (macOS bash 3.2 호환 위해 case statement 사용; associative array X)
while IFS= read -r src; do
    case "$src" in
        tools/airtableUpsertV6.mjs)
            dst="tools/capabilities/airtable-v6.md"
            ;;
        # 추가 도구 →
        # tools/yourTool.mjs)
        #     dst="tools/capabilities/your-doc.md"
        #     ;;
        *)
            continue ;;
    esac
    [ -f "$src" ] || continue
    CLAVIER_LOCAL_DEV=1 node "$src" --print-capability > "$dst" 2>/dev/null
    git add "$dst"
    echo "  ⚙  $dst regenerated from $src" >&2
done < <(git diff --cached --name-only --diff-filter=AM)

# ── (4) Mac 호스트별 단일 클론 강제 ──────────────────────────────────────
#       ~/bin/* alias 가 가리키는 scripts/tools/* dir = 이 호스트의 canonical.
#       자기 repo 가 alias 들과 무관하면 → 두 번째 클론 → 차단.
#       ~/bin 없으면 (OCI/web 등) → skip.
if [ -d "$HOME/bin" ]; then
    repo_root="$(git rev-parse --show-toplevel)"
    canonical_root=""
    canonical_alias=""
    found_self=false

    for link in "$HOME"/bin/*; do
        [ -L "$link" ] || continue
        target="$(readlink "$link")"
        # 절대경로 보장 (readlink 가 상대경로 줄 수도)
        case "$target" in
            /*) ;;
            *) target="$(cd "$(dirname "$link")" 2>/dev/null && cd "$(dirname "$target")" 2>/dev/null && pwd)/$(basename "$target")" ;;
        esac

        case "$target" in
            "$repo_root"/*)
                found_self=true
                ;;
            */scripts/tools/*|*/scripts/installScripts.sh|*/scripts/setup.sh)
                if [ -z "$canonical_root" ]; then
                    # …/scripts/tools/foo.mjs → 두 단 위 = scripts/
                    # …/scripts/installScripts.sh → 한 단 위 = scripts/
                    case "$target" in
                        */scripts/tools/*) canonical_root="$(cd "$(dirname "$(dirname "$target")")" 2>/dev/null && pwd)" ;;
                        *)                 canonical_root="$(cd "$(dirname "$target")"               2>/dev/null && pwd)" ;;
                    esac
                    canonical_alias="$link"
                fi
                ;;
        esac
    done

    if [ "$found_self" = false ] && [ -n "$canonical_root" ]; then
        echo "" >&2
        echo "‼️  이 클론은 이 호스트의 canonical clavier-scripts 가 아닙니다." >&2
        echo "" >&2
        echo "    현재 클론:  $repo_root" >&2
        echo "    canonical: $canonical_root" >&2
        echo "    (근거:     $canonical_alias → $(readlink "$canonical_alias"))" >&2
        echo "" >&2
        echo "    이 호스트의 작업은 canonical 쪽에서 하세요:" >&2
        echo "        cd \"$canonical_root\"" >&2
        echo "" >&2
        echo "    또는 *이 클론을* canonical 로 바꾸려면 (~/bin alias 들을 여기로 재바인딩):" >&2
        echo "        cd \"$repo_root\" && bash installScripts.sh" >&2
        echo "" >&2
        echo "    (OCI/web 처럼 ~/bin 없는 환경에서는 이 체크가 자동 skip 됩니다.)" >&2
        echo "" >&2
        exit 1
    fi
fi
