<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.clavier.screenshots-to-photos</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>/Users/clavier/Library/Scripts/import-screenshots-to-photos.sh</string>
	</array>
	<key>WatchPaths</key>
	<array>
		<string>/Users/clavier/Pictures/Screenshots</string>
	</array>
	<key>RunAtLoad</key>
	<false/>
	<key>StandardOutPath</key>
	<string>/Users/clavier/Library/Logs/screenshots-to-photos.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/clavier/Library/Logs/screenshots-to-photos.log</string>
</dict>
</plist>
